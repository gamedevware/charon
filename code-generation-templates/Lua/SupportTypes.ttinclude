#>
--- @class localizedText
--- @field _values table<string, string> Map of language -> text
--- @field _languageSwitcher any Language switcher for current/fallback language selection
--- @field _cachedValue string Cached resolved value
--- @field _cachedLanguageId string Language ID of cached value
local localizedText = {}
localizedText.__index = localizedText

-- FallbackOption enum
localizedText.FallbackOption = {
		OnNull = 'OnNull',        -- Fallback when the localized text is null (default)
		OnEmpty = 'OnEmpty',      -- Fallback when the localized text is an empty string
		OnNotDefined = 'OnNotDefined'  -- Fallback when the localized text is not defined
}

--- Create a new localized text instance
--- @param values table<string, string> Map of language ID to text value
--- @param languageSwitcher any The language switcher instance which points to currently selected language
--- @return localizedText
function localizedText.new(values, languageSwitcher)
		local self = setmetatable({}, localizedText)
		self._values = values or {}
		self._languageSwitcher = languageSwitcher
		self._cachedValue = nil
		self._cachedLanguageId = nil
		return self
end

--- Create a new language switcher for localized texts
--- @param currentLanguageId string The currently selected language ID (e.g. "en-US", "ru-RU")
--- @param fallbackLanguageId string The fallback language ID
--- @param primaryLanguageId string The primary/default language ID
--- @param fallbackOption string Optional fallback option ('OnNull', 'OnEmpty', 'OnNotDefined')
--- @return table Language switcher instance
function localizedText.newLanguageSwitcher(currentLanguageId, fallbackLanguageId, primaryLanguageId, fallbackOption)
		local self = {}
		self.currentLanguageId = currentLanguageId or "en-US"
		self.fallbackLanguageId = fallbackLanguageId or currentLanguageId or "en-US"
		self.primaryLanguageId = primaryLanguageId or currentLanguageId or "en-US"
		self.fallbackOption = fallbackOption or localizedText.FallbackOption.OnNull
		return self
end

--- Get the resolved text value for the current language with fallback support
--- @return string The text in the current language with fallback, or empty string if not found
function localizedText:value()
		if not self._languageSwitcher then
				for i,text in pairs(self._values) do
						return text or '';
				end
		end

		-- Return cached value if language hasn't changed
		if self._cachedLanguageId == self._languageSwitcher.currentLanguageId then
				return self._cachedValue or ''
		end

		-- Update cached value based on fallback option
		self._cachedLanguageId = self._languageSwitcher.currentLanguageId
		local result = ''

		local fallbackOption = self._languageSwitcher.fallbackOption or localizedText.FallbackOption.OnNull

		if fallbackOption == localizedText.FallbackOption.OnNotDefined then
				-- Fallback if not defined for current language
				if self._values[self._languageSwitcher.currentLanguageId] ~= nil then
						result = self._values[self._languageSwitcher.currentLanguageId] or ''
				elseif self._values[self._languageSwitcher.fallbackLanguageId] ~= nil then
						result = self._values[self._languageSwitcher.fallbackLanguageId] or ''
				elseif self._values[self._languageSwitcher.primaryLanguageId] ~= nil then
						result = self._values[self._languageSwitcher.primaryLanguageId] or ''
				end
		elseif fallbackOption == localizedText.FallbackOption.OnEmpty then
				-- Fallback if empty string
				result = self._values[self._languageSwitcher.currentLanguageId] or nil
				if not result or result == '' then
						result = self._values[self._languageSwitcher.fallbackLanguageId] or nil
				end
				if not result or result == '' then
						result = self._values[self._languageSwitcher.primaryLanguageId] or nil
				end
				result = result or ''
		else
				-- OnNull (default): Fallback if null/nil
				result = self._values[self._languageSwitcher.currentLanguageId] or
								 self._values[self._languageSwitcher.fallbackLanguageId] or
								 self._values[self._languageSwitcher.primaryLanguageId] or
								 ''
		end

		self._cachedValue = result
		return result
end

--- Get the text for a specific language (no fallback)
--- @param languageId string The language ID (e.g. "en-US", "ru-RU")
--- @return string | nil The text in that language, or nil
function localizedText:find(languageId)
		return self._values[languageId] or nil
end


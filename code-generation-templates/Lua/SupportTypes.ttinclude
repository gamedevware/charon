--- @param languageId string The language ID (e.g. "en-US", "ru-RU")
--- @return string | nil The text in that language, or nil
function localizedText:getValue(languageId)
		return self._values[languageId]
end

--- Set the text for a language
--- @param languageId string The language ID
--- @param value string The text value
function localizedText:setValue(languageId, value)
		self._values[languageId] = value
		-- Invalidate cache
		self._cachedLanguageId = nil
		self._cachedValue = nil
end

--- Get all available languages
--- @return table<string, string>
function localizedText:getValues()
		return self._values
end

--- Get the count of available languages
--- @return number
function localizedText:count()
		local cnt = 0
		for _ in pairs(self._values) do
				cnt = cnt + 1
		end
		return cnt
end

function localizedText:__tostring()
		return string.format("localizedText(%d languages)", self:count())
end

